# Analytics configuration for the mcpdesc.org site.
# Copy to `.env` for local overrides. Analytics stays DISABLED unless explicitly enabled.
# In Astro, only variables prefixed with PUBLIC_ are exposed to the browser.

# Enable analytics (production only). Any value other than "true" disables it.
PUBLIC_ANALYTICS_ENABLED=false

# Analytics provider. Currently only "plausible" is supported.
PUBLIC_ANALYTICS_PROVIDER=plausible

# Plausible site domain. Retained as the "site is configured" enable signal;
# the current Plausible script embeds the site identity in PUBLIC_PLAUSIBLE_SRC.
PUBLIC_PLAUSIBLE_DOMAIN=mcpdesc.org

# Plausible script source (the site-specific bundle provided by Plausible).
PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/pa-Cvk4BmjwCv3FXrU6y2Rcl.js
