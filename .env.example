# Analytics configuration for the MCP Toolkit site.
# Copy to `.env` for local overrides. Analytics stays DISABLED unless explicitly enabled.
# In Astro, only variables prefixed with PUBLIC_ are exposed to the browser.

# Enable analytics (production only). Any value other than "true" disables it.
PUBLIC_ANALYTICS_ENABLED=false

# Analytics provider. Currently only "plausible" is supported.
PUBLIC_ANALYTICS_PROVIDER=plausible

# Plausible data-domain for this site.
PUBLIC_PLAUSIBLE_DOMAIN=mcptoolkit.org

# Plausible script source.
PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js
