---
import BaseLayout from '../layouts/BaseLayout.astro';

const repoUrl = 'https://github.com/cisco-open/mcptoolkit-editor';
const embedRepoUrl = 'https://github.com/mcpdesc/editor.mcpdesc.org';
const npmUrl = 'https://www.npmjs.com/package/@cisco_open/mcptoolkit-editor-dist';

const features = [
  {
    title: 'Schema-driven editing',
    body: 'Monaco editor with JSON Schema autocomplete, inline squiggles, folding, and syntax highlighting for JSON and YAML.',
  },
  {
    title: 'Real-time validation',
    body: 'AJV validation against the MCP Description schema, plus semantic warnings for semver, empty capabilities, and duplicate names.',
  },
  {
    title: 'Interactive cards preview',
    body: 'Collapsible cards for server info, transports, security, tools, resources, and prompts. Click any item and jump to its source.',
  },
  {
    title: 'Markdown & export',
    body: 'Render Handlebars documentation, convert JSON \u2194 YAML in one click, and export as .mcpdesc.json, .mcpdesc.yaml, or .md.',
  },
];
---

<BaseLayout
  title="Live MCP Description Editor"
  description="A web-based editor for MCP Description documents \u2014 author, validate, preview, and export, in your browser."
  pageType="live_editor_landing"
>
  <section class="py-10 text-center">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Live MCP Description Editor</h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600 dark:text-slate-300">
      <strong>Preview and update</strong> MCP Description documents — in your browser.
    </p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <span
        aria-disabled="true"
        title="The hosted Live Editor is coming soon"
        class="inline-block cursor-not-allowed rounded-md bg-slate-200 px-6 py-3 text-lg font-medium text-slate-500 dark:bg-slate-800 dark:text-slate-400"
      >
        Open the Editor
      </span>
      <a
        href={repoUrl}
        data-analytics-outbound="github"
        rel="noopener"
        class="inline-block rounded-md border border-slate-300 px-6 py-3 text-lg font-medium text-slate-800 hover:border-slate-400 dark:border-slate-700 dark:text-slate-100"
      >
        View on GitHub
      </a>
    </div>
    <p class="mt-3 text-xs text-slate-500">
      Pure client-side. No account, no backend. Your document never leaves your device.
    </p>
  </section>

  <section class="mt-6">
    <img
      src="/img/editor-screenshot.png"
      alt="The Live MCP Description Editor showing a YAML MCP Description on the left and an interactive cards preview on the right."
      width="1077"
      height="537"
      loading="lazy"
      class="mx-auto h-auto w-full max-w-4xl rounded-lg border border-slate-200 shadow-sm dark:border-slate-800"
    />
  </section>

  <section class="mt-12 grid gap-4 sm:grid-cols-2">
    {
      features.map((f) => (
        <div class="rounded-lg border border-slate-200 p-5 dark:border-slate-800">
          <h2 class="font-semibold">{f.title}</h2>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">{f.body}</p>
        </div>
      ))
    }
  </section>

  <section class="mt-12 rounded-lg bg-slate-50 p-6 dark:bg-slate-900">
    <h2 class="text-2xl font-bold tracking-tight">Source code and privacy</h2>
    <p class="mt-2 font-medium text-slate-600 dark:text-slate-300">Your MCP Description stays in your browser.</p>
    <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">
      No MCP server description content is uploaded to our servers. Edits persist locally
      via your browser's storage, and analytics only tracks anonymous product usage events.
    </p>
    <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">
      The Live Editor proposed on the "Try It" page loads the TypeScript module 'MCP Description Editor" from{' '}
      <a
        href={npmUrl}
        data-analytics-outbound="npm"
        rel="noopener"
        class="font-medium text-[var(--color-brand)] hover:underline"
      >
        npm
      </a>. Both the Live Editor and the TypeScript module are opensource.
    </p>
    <p class="mt-3 text-sm flex flex-wrap gap-x-6 gap-y-1 text-slate-600 dark:text-slate-300">
      <a
        class="font-medium text-[var(--color-brand)] hover:underline"
        href="/docs/privacy"
      >
        Read the privacy statement →
      </a>
      <a
        class="font-medium text-[var(--color-brand)] hover:underline"
        href={embedRepoUrl}
        data-analytics-outbound="github"
        rel="noopener"
      >
        Live Editor on GitHub →
      </a>
      <a
        class="font-medium text-[var(--color-brand)] hover:underline"
        href={repoUrl}
        data-analytics-outbound="github"
        rel="noopener"
      >
        TypeScript Editor Module on GitHub →
      </a>
    </p>
  </section>
</BaseLayout>
