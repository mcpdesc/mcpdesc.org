---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const showDrafts = import.meta.env.DEV;
const posts = (await getCollection('blog'))
  .filter((p) => showDrafts || !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog" description={'Posts and updates from the {mcpdesc} Community.'} pageType="blog_index">
  <h1 class="text-3xl font-bold tracking-tight">Blog</h1>
  <ul class="mt-8 list-none space-y-6 pl-0">
    {
      posts.map((post) => (
        <li class="border-b border-slate-200 pb-6 last:border-b-0 dark:border-slate-800">
          <a
            class="text-2xl font-semibold text-slate-900 hover:underline dark:text-slate-100"
            href={`/blog/${post.id}`}
          >
            {post.data.listTitle ?? post.data.title}
          </a>
          {
            showDrafts && post.data.draft && (
              <p class="mt-2">
                <span class="inline-flex items-center rounded-full border border-amber-500/40 bg-amber-50 px-2 py-0.5 text-xs font-semibold uppercase tracking-wide text-amber-700 dark:border-amber-400/40 dark:bg-amber-500/10 dark:text-amber-300">
                  Draft (visible only in dev env)
                </span>
              </p>
            )
          }
          <p class="mt-1 text-sm text-slate-500">
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { dateStyle: 'medium' })}
            </time>
            {' · '}
            {post.data.author}
          </p>
          <p class="mt-2 text-slate-600 dark:text-slate-300">{post.data.description}</p>
        </li>
      ))
    }
  </ul>
</BaseLayout>
