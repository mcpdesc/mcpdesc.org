---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

type Status = 'Available' | 'Planned' | 'Exploration' | 'Coming soon';

// The catalog is data-driven: one YAML file per tool under tools/.
// Display order is controlled by tools/catalog.yaml (the TOC).
// The site never displays which spec version a tool supports — each tool self-declares
// that in its own README via the mcpdesc badge (see docs/tool-badge.md and /docs/add-a-tool).
const showDrafts = import.meta.env.DEV;
const catalogEntry = await getEntry('catalog', 'catalog');
const categoriesEntry = await getEntry('toolCategories', 'categories');
const categoryDefs = categoriesEntry?.data.categories ?? [];
const toc: string[] = catalogEntry?.data.toc ?? [];
const toolMap = Object.fromEntries(
  (await getCollection('tools')).map((e) => [e.data.id, e.data])
);
const tools = toc
  .map((id) => toolMap[id])
  .filter((t): t is NonNullable<typeof t> => !!t && (showDrafts || t.visibility === 'public'));

const statusBadge: Record<Status, string> = {
  Available:
    'border-emerald-500/40 bg-emerald-50 text-emerald-700 dark:border-emerald-400/40 dark:bg-emerald-500/10 dark:text-emerald-300',
  Planned:
    'border-slate-400/40 bg-slate-50 text-slate-600 dark:border-slate-500/40 dark:bg-slate-500/10 dark:text-slate-300',
  Exploration:
    'border-amber-500/40 bg-amber-50 text-amber-700 dark:border-amber-400/40 dark:bg-amber-500/10 dark:text-amber-300',
  'Coming soon':
    'border-slate-400/40 bg-slate-50 text-slate-600 dark:border-slate-500/40 dark:bg-slate-500/10 dark:text-slate-300',
};
---

<BaseLayout
  title="Tools"
  description="Open-source tools that support or use the MCP Description (mcpdesc) format."
  pageType="tools"
>
  <section class="py-10 text-center">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Community Tools</h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600 dark:text-slate-300">
      A <strong>curated list</strong> of tools and projects that support, integrate with or build
      on the <code>mcpdesc</code> format.
    </p>
  </section>

  <section>
    <h2 class="text-2xl font-bold tracking-tight">Add your own tool</h2>
    <p class="mt-3 max-w-3xl text-slate-600 dark:text-slate-300">
      Did you build something that support the <code>mcpdesc</code> format?
    </p>
    <div class="mt-4 flex flex-wrap gap-3">
      <a
        href="/docs/add-a-tool"
        class="rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-800 no-underline hover:border-slate-400 dark:border-slate-700 dark:text-slate-100"
      >
        How to add a tool
      </a>
      <a
        href="https://github.com/mcpdesc/mcpdesc.org/issues/new?template=tool-submission.yml"
        target="_blank"
        rel="noopener"
        data-analytics-outbound="github"
        class="rounded-md bg-[var(--color-brand)] px-4 py-2 text-sm font-medium text-white no-underline hover:bg-[var(--color-brand-dark)]"
      >
        Submit a tool
      </a>

    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-2xl font-bold tracking-tight">Open source Tools</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
    {
      tools.map((tool) => {
        const hasMetadata = tool.languages.length > 0 || tool.registries.length > 0;
        return (
          <article
            id={tool.id}
            class:list={[
              'relative flex flex-col rounded-lg border border-slate-200 p-4 transition-colors dark:border-slate-800',
              tool.href
                ? 'hover:border-slate-400 dark:hover:border-slate-600'
                : 'opacity-70',
            ]}
          >
            <div class="flex items-start justify-between gap-3">
              {tool.href ? (
                <h3 class="m-0 font-mono text-lg font-semibold text-slate-900 dark:text-slate-100">
                  <a
                    href={tool.href}
                    target={tool.outbound ? '_blank' : undefined}
                    data-analytics-outbound={tool.outbound ? 'github' : undefined}
                    rel={tool.outbound ? 'noopener' : undefined}
                    class="text-slate-900 no-underline after:absolute after:inset-0 after:content-[''] visited:text-slate-900 hover:text-[var(--color-brand)] hover:underline dark:text-slate-100 dark:visited:text-slate-100"
                  >
                    {tool.name}
                  </a>
                </h3>
              ) : (
                <h3 class="m-0 font-mono text-lg font-semibold text-slate-900 dark:text-slate-100">{tool.name}</h3>
              )}
              {tool.status !== 'Available' && (
                <span
                  class={`shrink-0 rounded-full border px-2 py-0.5 text-xs font-semibold uppercase tracking-wide ${statusBadge[tool.status]}`}
                >
                  {tool.status}
                </span>
              )}
            </div>

            <p class="m-0 mt-2 text-sm leading-5 text-slate-600 dark:text-slate-400">{tool.tagline}</p>

            {tool.categories.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-1.5">
                {tool.categories.map((cat) => (
                  <span class="rounded-full border border-slate-200 bg-slate-50 px-2 py-0.5 text-xs text-slate-500 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-400">
                    {categoryDefs.find(c => c.id === cat)?.name ?? cat}
                  </span>
                ))}
              </div>
            )}

            {showDrafts && tool.visibility === 'draft' && (
              <p class="m-0 mt-2">
                <span class="inline-flex items-center rounded-full border border-amber-500/40 bg-amber-50 px-2 py-0.5 text-xs font-semibold uppercase tracking-wide text-amber-700 dark:border-amber-400/40 dark:bg-amber-500/10 dark:text-amber-300">
                  Draft (visible only in dev env)
                </span>
              </p>
            )}

            {hasMetadata && (
              <div class="mt-auto pt-3">
                <div class="border-t border-slate-100 pt-3 dark:border-slate-800">
                  <p class="relative z-10 m-0 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-slate-500 dark:text-slate-400">
                    {tool.languages.map((language, i) => (
                      <>
                        {i > 0 && <span aria-hidden="true">·</span>}
                        <span>{language}</span>
                      </>
                    ))}
                    {tool.languages.length > 0 && tool.registries.length > 0 && (
                      <span aria-hidden="true">·</span>
                    )}
                    {tool.registries.map((reg, i) => (
                      <>
                        {i > 0 && <span aria-hidden="true">·</span>}
                        <a
                          href={reg.url}
                          target="_blank"
                          rel="noopener"
                          class="font-medium text-[var(--color-brand)] hover:underline"
                        >
                          {reg.name} <span aria-hidden="true">↗</span>
                        </a>
                      </>
                    ))}
                  </p>
                </div>
              </div>
            )}
          </article>
        );
      })
    }
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-2xl font-bold tracking-tight">Categories</h2>
    <table class="mt-4 w-full text-sm">
      <thead>
        <tr class="border-b border-slate-200 dark:border-slate-800">
          <th class="pb-2 pr-6 text-left font-semibold text-slate-700 dark:text-slate-300 w-32">Tag</th>
          <th class="pb-2 text-left font-semibold text-slate-700 dark:text-slate-300">Definition</th>
        </tr>
      </thead>
      <tbody>
        {categoryDefs.map((cat) => (
          <tr class="border-b border-slate-100 dark:border-slate-900">
            <td class="py-2 pr-6 align-top">
              <span class="inline-block rounded-full border border-slate-200 bg-slate-50 px-2 py-0.5 text-xs text-slate-500 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-400">
                {cat.name}
              </span>
            </td>
            <td class="py-2 text-slate-600 dark:text-slate-400">{cat.description}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

</BaseLayout>
