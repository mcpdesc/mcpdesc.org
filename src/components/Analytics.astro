---
// Injects the Plausible script (production/enabled only) and wires safe,
// declarative custom events. UI never calls window.plausible directly.
//
// Opt-in event wiring via data attributes:
//   <a data-analytics-outbound="github" ...>      -> outbound_link_clicked
//   <a data-analytics-cta="open_editor" ...>       -> campaign_cta_clicked
const enabled = import.meta.env.PUBLIC_ANALYTICS_ENABLED === 'true';
const provider = import.meta.env.PUBLIC_ANALYTICS_PROVIDER;
const domain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const src = import.meta.env.PUBLIC_PLAUSIBLE_SRC ?? 'https://plausible.io/js/script.js';

const usePlausible = enabled && provider === 'plausible' && Boolean(domain);
---

{usePlausible && <script is:inline defer data-domain={domain} src={src}></script>}

<script>
  import { analytics } from '../analytics/analytics';

  const ALLOWED_OUTBOUND = new Set([
    'github',
    'npm',
    'docs',
    'companion_site',
    'issue',
    'other',
  ]);

  function bind() {
    document.querySelectorAll<HTMLElement>('[data-analytics-outbound]').forEach((el) => {
      if (el.dataset.analyticsBound) return;
      el.dataset.analyticsBound = 'true';
      el.addEventListener('click', () => {
        const raw = el.dataset.analyticsOutbound ?? 'other';
        const outbound_target = ALLOWED_OUTBOUND.has(raw) ? raw : 'other';
        analytics.track('outbound_link_clicked', { outbound_target });
      });
    });

    document.querySelectorAll<HTMLElement>('[data-analytics-cta]').forEach((el) => {
      if (el.dataset.analyticsBound) return;
      el.dataset.analyticsBound = 'true';
      el.addEventListener('click', () => {
        analytics.track('campaign_cta_clicked', {
          cta_id: el.dataset.analyticsCta,
          page_type: document.body.dataset.pageType,
        });
      });
    });
  }

  bind();
  document.addEventListener('astro:page-load', bind);
</script>
